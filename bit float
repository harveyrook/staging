    fn pint_div_3937_by_31_prints_results() {
        let a = encode(3937, 16);
        let b = encode(31, 16);
        let (q, r) = pint_div(&a, &b).expect("div");

        let q_u = decode(&q);
        let r_u = decode(&r);

        println!("dividend=3937 divisor=31 quotient={q_u} remainder={r_u}");

        assert_eq!(q_u, 127);
        assert_eq!(r_u, 0);
