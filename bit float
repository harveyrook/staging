        let a = encode(3, 8);
        let b = encode(5, 8);
        let (diff, borrow) = pint_sub(&a, &b).expect("sub");
        // 3 - 5 wraps to 254 in 8-bit unsigned arithmetic
        assert_eq!(decode(&diff), 254);
        approx_eq(borrow.p_one, 1.0);
    }

