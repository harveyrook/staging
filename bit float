    #[test]
    // Divides 899 by a probabilistic unsigned value whose lower 8 bits are 0.50.
    // We validate successful execution and invariant preservation rather than a
    // deterministic integer quotient/remainder.
    fn pint_div_by_probabilistic_lower_8_half_bits() {
        let width = 16;
        let dividend = encode(899, width);

        let mut divisor_bits = vec![pbit_new(0.0); width];
        for bit in divisor_bits.iter_mut().take(8) {
            *bit = pbit_new(0.5);
        }
        let divisor = PInt::new(divisor_bits, width, false).expect("valid probabilistic divisor");

        let (q, r) = pint_div(&dividend, &divisor).expect("division should succeed");

        let divisor_arr: Vec<f64> = divisor.bits.iter().map(|b| b.p_one).collect();
        let q_arr: Vec<f64> = q.bits.iter().map(|b| b.p_one).collect();
        let r_arr: Vec<f64> = r.bits.iter().map(|b| b.p_one).collect();

        println!("dividend_u128=899");
        println!("divisor_bits={:?}", divisor_arr);
        println!("q_bits={:?}", q_arr);
        println!("r_bits={:?}", r_arr);

        assert_eq!(q.width, width);
        assert_eq!(r.width, width);
        assert!(!q.signed);
        assert!(!r.signed);

        for bit in &q.bits {
            assert_bounded(bit.p_one);
        }
        for bit in &r.bits {
            assert_bounded(bit.p_one);
        }
    }

    #[test]
    // Reconstruct dividend from quotient and remainder: q*b + r == a.
    fn pint_div_quotient_remainder_reconstruct() {
        let a = encode(100, 16);
        let b = encode(7, 16);
        let (q, r) = pint_div(&a, &b).expect("div");
        let (prod, _) = pint_add(&pint_mul(&q, &b).expect("mul"), &r).expect("add");
        assert_eq!(decode(&prod), 100);
    }
